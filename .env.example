# Copy to .env.local — keys are exposed in the browser bundle; use a backend proxy for production.

# Maps & driving: https://openrouteservice.org/
VITE_OPENROUTESERVICE_API_KEY=

# Optional AI route tips: https://aistudio.google.com/apikey — Gemini (no quotes)
VITE_GEMINI_API_KEY=
# Optional: default free-tier chain starts at gemini-2.5-flash-lite (override to lock one model)
# VITE_GEMINI_MODEL=gemini-2.5-flash-lite
